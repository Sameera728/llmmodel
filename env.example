import React, { useState, useEffect, useRef } from "react";
import { Sliders, Play, Trash2, LineChart, Cpu, Zap, AlertTriangle, CheckCircle2, RefreshCw, Terminal, Info } from "lucide-react";
import { TrainingJob } from "../types";

interface TrainingPanelProps {
  onNotify: (msg: string) => void;
}

export default function TrainingPanel({ onNotify }: TrainingPanelProps) {
  const [job, setJob] = useState<TrainingJob | null>(null);
  
  // Form parameters
  const [datasetName, setDatasetName] = useState("medical_instructions.json");
  const [epochs, setEpochs] = useState(3);
  const [batchSize, setBatchSize] = useState(4);
  const [learningRate, setLearningRate] = useState(2e-4);
  const [useQlora, setUseQlora] = useState(true);
  
  const [targetModules, setTargetModules] = useState<Record<string, boolean>>({
    q_proj: true,
    k_proj: false,
    v_proj: true,
    o_proj: false,
    gate_proj: true,
    up_proj: false,
    down_proj: false,
  });

  const [terminalLogs, setTerminalLogs] = useState<string[]>([]);
  const terminalEndRef = useRef<HTMLDivElement>(null);

  useEffect(() => {
    const interval = setInterval(fetchTrainingStatus, 2000);
    return () => clearInterval(interval);
  }, []);

  useEffect(() => {
    terminalEndRef.current?.scrollIntoView({ behavior: "smooth" });
  }, [terminalLogs]);

  const fetchTrainingStatus = async () => {
    try {
      const res = await fetch("/api/train/status");
      const data = await res.json();
      if (data.success && data.job) {
        setJob(data.job);
        updateSimulatedLogs(data.job);
      } else if (data.success && !data.job) {
        setJob(null);
      }
    } catch (e) {
      console.error(e);
    }
  };

  const handleLaunch = async () => {
    setTerminalLogs([
      "> [SYSTEM] Initializing distributed environment...",
      "> [SYSTEM] Mapping active GPUs... Found 1 NVIDIA RTX 4090",
      "> [DATASET] Reading training dataset configurations...",
      `> [DATASET] Running clean_raw_sample() on '${datasetName}'`,
      `> [DATASET] Successfully loaded 1,420 instruction pairs. Alignment done.`,
    ]);

    try {
      const res = await fetch("/api/train/start", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          dataset_name: datasetName,
          epochs,
          batch_size: batchSize,
          learning_rate: learningRate,
        }),
      });
      const data = await res.json();
      if (data.success) {
        onNotify("LoRA training initiated!");
        setJob(data.job);
      }
    } catch (e) {
      onNotify("Failed to initiate training");
    }
  };

  const handleReset = async () => {
    try {
      await fetch("/api/train/reset", { method: "POST" });
      setJob(null);
      setTerminalLogs([]);
      onNotify("Workspace clean.");
    } catch (e) {
      console.error(e);
    }
  };

  const updateSimulatedLogs = (activeJob: TrainingJob) => {
    if (activeJob.status !== "running") return;
    
    const logs = [...terminalLogs];
    const step = activeJob.steps;
    const currentLoss = activeJob.lossHistory[activeJob.lossHistory.length - 1] || 1.8;
    
    // Periodically add line entries reflecting train checkpoints
    if (step > 0 && logs.length < (step / 10) + 5) {
      logs.push(
        `> [TRAIN] Step ${step}/${activeJob.totalSteps} | Loss: ${currentLoss} | LR: ${(activeJob.learningRate * (1 - step/activeJob.totalSteps)).toFixed(6)}`
      );
      if (step % 50 === 0) {
        logs.push(`> [SAVER] Writing adapter weight checkpoints inside ./checkpoints/checkpoint-${step}/ ... Saved.`);
      }
      setTerminalLogs(logs);
    }
  };

  const toggleTarget = (key: string) => {
    setTargetModules((prev) => ({
      ...prev,
      [key]: !prev[key],
    }));
  };

  return (
    <div className="grid grid-cols-1 lg:grid-cols-3 gap-6 items-stretch h-[650px] overflow-hidden">
      {/* Parameters panel */}
      <div className="lg:col-span-1 bg-zinc-900/40 backdrop-blur-md rounded-xl border border-zinc-800 p-4 flex flex-col h-full overflow-y-auto custom-scrollbar gap-4">
        <div>
          <div className="flex items-center gap-2 mb-3">
            <Sliders size={15} className="text-blue-500" />
            <h3 className="text-xs font-semibold text-zinc-400 uppercase tracking-wider">
              Fine-Tuning Configs
            </h3>
          </div>

          <div className="space-y-3.5 text-xs">
            <div>
              <label className="block text-zinc-400 mb-1.5 font-medium">Dataset Filename</label>
              <select
                value={datasetName}
                onChange={(e) => setDatasetName(e.target.value)}
                disabled={job !== null}
                className="w-full bg-[#09090b] border border-zinc-800 rounded-lg p-2 text-zinc-300 outline-none focus:border-blue-500/50"
              >
                <option value="medical_instructions.json">medical_instructions.json (1,420 pairs)</option>
                <option value="legal_rules_alpaca.json">legal_rules_alpaca.json (820 pairs)</option>
                <option value="finance_qna_sft.json">finance_qna_sft.json (2,100 pairs)</option>
              </select>
            </div>

            <div className="grid grid-cols-2 gap-3">
              <div>
                <label className="block text-zinc-400 mb-1.5 font-medium">Epoch Allocation</label>
                <input
                  type="number"
                  min="1"
                  max="10"
                  value={epochs}
                  onChange={(e) => setEpochs(parseInt(e.target.value) || 3)}
                  disabled={job !== null}
                  className="w-full bg-[#09090b] border border-zinc-800 rounded-lg p-2 text-zinc-300 outline-none focus:border-blue-500/50 font-mono text-center"
                />
              </div>
              <div>
                <label className="block text-zinc-400 mb-1.5 font-medium">Batch Size</label>
                <input
                  type="number"
                  min="1"
                  max="64"
                  value={batchSize}
                  onChange={(e) => setBatchSize(parseInt(e.target.value) || 4)}
                  disabled={job !== null}
                  className="w-full bg-[#09090b] border border-zinc-800 rounded-lg p-2 text-zinc-300 outline-none focus:border-blue-500/50 font-mono text-center"
                />
              </div>
            </div>

            <div>
              <label className="block text-zinc-400 mb-1.5 font-medium">Learning Rate</label>
              <input
                type="text"
                value={learningRate}
                onChange={(e) => setLearningRate(parseFloat(e.target.value) || 2e-4)}
                disabled={job !== null}
                className="w-full bg-[#09090b] border border-zinc-800 rounded-lg p-2 text-zinc-300 outline-none focus:border-blue-500/50 font-mono text-center"
              />
            </div>

            {/* QLoRA vs LoRA */}
            <div className="flex items-center justify-between p-3 bg-[#09090b]/45 rounded-lg border border-zinc-800/80 mt-4 select-none">
              <div className="text-xs">
                <span className="font-semibold text-zinc-200 block">Use 4-Bit QLoRA</span>
                <span className="text-[10px] text-zinc-500">Enable NF4 Quantization (saves 65% VRAM)</span>
              </div>
              <input
                type="checkbox"
                checked={useQlora}
                onChange={(e) => setUseQlora(e.target.checked)}
                disabled={job !== null}
                className="h-4 w-4 accent-blue-500 cursor-pointer"
              />
            </div>
          </div>
        </div>

        {/* Target Modules mapping */}
        <div className="border-t border-zinc-800 pt-4 mt-1">
          <h3 className="text-xs font-semibold text-zinc-400 uppercase tracking-wider mb-2.5">
            LoRA Target Layers
          </h3>
          <div className="grid grid-cols-2 gap-2 text-[10px] font-mono">
            {Object.keys(targetModules).map((mod) => (
              <button
                key={mod}
                onClick={() => toggleTarget(mod)}
                disabled={job !== null}
                className={`flex items-center justify-between p-2 rounded-lg border text-left transition-colors ${
                  targetModules[mod]
                    ? "bg-blue-600/10 border-blue-500/30 text-blue-400 font-bold"
                    : "bg-[#09090b]/45 border-zinc-800 text-zinc-500 hover:border-zinc-700/80"
                }`}
              >
                <span>{mod}</span>
                <span className={`h-1.5 w-1.5 rounded-full ${targetModules[mod] ? "bg-blue-500" : "bg-transparent"}`}></span>
              </button>
            ))}
          </div>
        </div>

        {/* Trigger Button */}
        <div className="mt-auto">
          {job ? (
            <button
              onClick={handleReset}
              className="w-full flex items-center justify-center gap-2 py-2.5 bg-zinc-800 hover:bg-zinc-700 border border-zinc-700 text-zinc-300 font-semibold rounded-lg text-xs transition-colors cursor-pointer"
            >
              <Trash2 size={13} /> Reset Environment
            </button>
          ) : (
            <button
              onClick={handleLaunch}
              className="w-full flex items-center justify-center gap-2 py-2.5 bg-blue-600 hover:bg-blue-500 text-white font-semibold rounded-lg text-xs transition-colors cursor-pointer shadow-lg shadow-blue-500/10"
            >
              <Play size={13} fill="currentColor" /> Launch Training Run
            </button>
          )}
        </div>
      </div>

      {/* Analytics Visualization and Console Logs */}
      <div className="lg:col-span-2 flex flex-col h-full gap-4 overflow-hidden">
        {/* Graph & Stats Screen */}
        <div className="bg-zinc-900/40 backdrop-blur-md rounded-xl border border-zinc-800 p-5 flex flex-col h-[340px] shrink-0">
          <div className="flex items-center justify-between pb-3 mb-4 border-b border-zinc-800">
            <div className="flex items-center gap-2">
              <LineChart size={16} className="text-blue-500" />
              <h3 className="text-sm font-semibold text-zinc-100">Hyperparameter Optimization Loop</h3>
            </div>
            <span className="px-2 py-0.5 rounded bg-zinc-800 border border-zinc-800 text-[10px] text-blue-400 font-mono">
              {job ? `JOB: ${job.status.toUpperCase()}` : "CORE: IDLE"}
            </span>
          </div>

          {job ? (
            <div className="flex-1 grid grid-cols-1 md:grid-cols-3 gap-4 items-stretch overflow-hidden">
              {/* Numerical stats */}
              <div className="md:col-span-1 space-y-3 font-mono text-[11px] bg-[#0c0c0e] rounded-xl border border-zinc-800/50 p-4">
                <div className="flex justify-between border-b border-zinc-900 pb-1.5">
                  <span className="text-zinc-500">Progression:</span>
                  <span className="text-blue-400 font-bold">{job.progress}%</span>
                </div>
                <div className="flex justify-between border-b border-zinc-900 pb-1.5">
                  <span className="text-zinc-500">Cross Loss:</span>
                  <span className="text-rose-400 font-bold">{job.lossHistory[job.lossHistory.length - 1] || "N/A"}</span>
                </div>
                <div className="flex justify-between border-b border-zinc-900 pb-1.5">
                  <span className="text-zinc-500">Optimizer step:</span>
                  <span className="text-zinc-300 font-bold">{job.steps}/{job.totalSteps}</span>
                </div>
                <div className="flex justify-between border-b border-zinc-900 pb-1.5">
                  <span className="text-zinc-500">Precision state:</span>
                  <span className="text-emerald-400 font-bold">4-bit (NF4)</span>
                </div>
                <div className="flex justify-between">
                  <span className="text-zinc-500">Time elapsed:</span>
                  <span className="text-zinc-400 font-bold">{job.elapsed}s</span>
                </div>
              </div>

              {/* Loss Visualization container */}
              <div className="md:col-span-2 bg-[#09090b]/45 rounded-xl border border-zinc-800/50 p-4 flex flex-col justify-between relative overflow-hidden">
                <div className="flex justify-between items-center text-[10px] text-zinc-500 font-mono mb-2">
                  <span>LOSS CURVE (Cross-Entropy)</span>
                  <span>INIT: 1.8000 &rarr; CURR: {job.lossHistory[job.lossHistory.length - 1] || "0.0000"}</span>
                </div>
                
                {/* Simulated SVG Graph rendering loss decrements */}
                <div className="flex-1 w-full bg-[#09090b]/80 rounded-lg relative overflow-hidden flex items-end px-4 border border-zinc-900 shadow-inner">
                  {/* Grid Lines */}
                  <div className="absolute inset-0 flex flex-col justify-between p-2 select-none pointer-events-none opacity-20">
                    <div className="border-b border-zinc-800 w-full"></div>
                    <div className="border-b border-zinc-800 w-full"></div>
                    <div className="border-b border-zinc-800 w-full"></div>
                  </div>

                  <svg className="w-full h-full pt-4 pb-2" viewBox="0 0 100 100" preserveAspectRatio="none">
                    <polyline
                      fill="none"
                      stroke="#3b82f6"
                      strokeWidth="2"
                      points={job.lossHistory
                        .map((val, idx) => {
                          const x = (idx / (job.lossHistory.length - 1 || 1)) * 100;
                          // Invert loss so lower loss is higher on graph
                          const y = 100 - ((val / 2) * 100);
                          return `${x},${y}`;
                        })
                        .join(" ")}
                    />
                  </svg>
                </div>
              </div>
            </div>
          ) : (
            <div className="flex-1 flex flex-col items-center justify-center text-center">
              <Cpu size={32} className="text-zinc-700/60 mb-2 animate-pulse" />
              <p className="text-xs text-zinc-500 font-semibold">Inference Engine Standby</p>
              <p className="text-[10px] text-zinc-600 mt-1 max-w-sm">
                Choose parameters on the left sidebar and click "Launch Training Run" to verify tokenization alignment, loss calculations, and TensorBoard logging hooks.
              </p>
            </div>
          )}
        </div>

        {/* Bash Terminal Console Logs */}
        <div className="bg-[#09090b] border border-zinc-800 rounded-xl flex flex-col flex-1 overflow-hidden">
          <div className="flex items-center gap-2 px-4 py-2 bg-zinc-900/40 border-b border-zinc-800 text-zinc-400 font-mono text-[10px] shrink-0 select-none">
            <Terminal size={12} className="text-zinc-500" />
            <span>CUDA Execution Sandbox Terminal Logs</span>
          </div>

          <div className="flex-1 overflow-y-auto p-4 space-y-1.5 font-mono text-[10.5px] text-zinc-400 custom-scrollbar select-text">
            {terminalLogs.length > 0 ? (
              terminalLogs.map((log, idx) => (
                <div key={idx} className="whitespace-pre-wrap leading-relaxed">
                  {log}
                </div>
              ))
            ) : (
              <div className="flex items-center justify-center h-full text-zinc-700 select-none">
                $ bash scripts/accelerate_launch.sh --config=configs/config.yaml
              </div>
            )}
            <div ref={terminalEndRef} />
          </div>
        </div>
      </div>
    </div>
  );
}
